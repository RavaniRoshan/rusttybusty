---
import MascotNav from './MascotNav.jsx';

const currentPath = Astro.url.pathname;
const BASE_URL = import.meta.env.BASE_URL;

// Precomputed URLs using base path
const homeUrl = BASE_URL;
const architectureUrl = `${BASE_URL}architecture`;
const walkthroughUrl = `${BASE_URL}walkthrough/node-structure`;
const playgroundUrl = `${BASE_URL}playground`;

// Build mobile nav HTML at build time
const mobileNavHTML = `
    <a href="${homeUrl}" class="mobile-link">Home</a>
    <a href="${architectureUrl}" class="mobile-link">Architecture</a>
    <a href="${walkthroughUrl}" class="mobile-link">Walkthrough</a>
    <a href="${playgroundUrl}" class="mobile-link">Playground</a>
  `;
---

<nav class="split-nav">
   <div class="nav-island nav-island-left">
     <a href={homeUrl} class="nav-logo">
       <MascotNav />
       <span>Immutable DOM</span>
     </a>
   </div>
  
   <div class="nav-island nav-island-right">
     <ul class="nav-links">
       <li><a href={homeUrl} class:list={currentPath === homeUrl ? ['active'] : []}>Home</a></li>
       <li><a href={architectureUrl} class:list={currentPath === architectureUrl || currentPath.startsWith(architectureUrl) ? ['active'] : []}>Architecture</a></li>
       <li><a href={walkthroughUrl} class:list={currentPath.startsWith(walkthroughUrl) ? ['active'] : []}>Walkthrough</a></li>
       <li><a href={playgroundUrl} class:list={currentPath === playgroundUrl ? ['active'] : []}>Playground</a></li>
     </ul>
    
    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
      <svg class="sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
      <svg class="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>

    <button class="nav-toggle" aria-label="Toggle navigation">
      <span class="line-1"></span>
      <span class="line-2"></span>
      <span class="line-3"></span>
    </button>
  </div>
</nav>

<script define:vars={{ mobileNavHTML }}>
  // Mobile Nav Logic
  const navToggle = document.querySelector('.nav-toggle');
  const navOverlay = document.createElement('div');
  navOverlay.className = 'nav-overlay';
  navOverlay.innerHTML = mobileNavHTML;
  document.body.appendChild(navOverlay);

  const mobileLinks = navOverlay.querySelectorAll('a');
  
  navToggle.addEventListener('click', () => {
    navToggle.classList.toggle('active');
    navOverlay.classList.toggle('open');
    document.body.style.overflow = navOverlay.classList.contains('open') ? 'hidden' : '';
  });

  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      navToggle.classList.remove('active');
      navOverlay.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && navOverlay.classList.contains('open')) {
      navToggle.classList.remove('active');
      navOverlay.classList.remove('open');
      document.body.style.overflow = '';
    }
  });

  // Theme Toggle Logic
  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
    const newTheme = currentTheme === 'light' ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', newTheme);
    localStorage.setItem('theme', newTheme);
  });
</script>
